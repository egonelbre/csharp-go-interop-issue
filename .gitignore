# Build artifacts in reorganized directories
dotnet-go-reproducer/bin/
dotnet-go-reproducer/obj/
dotnet-go-reproducer/libgolib.so
dotnet-go-reproducer/libgolib.h
dotnet-go-reproducer/libsigstack_helper.so

go-runtime-bug/libgolib.so
go-runtime-bug/host

coreclr-pal-bug/bin/
coreclr-pal-bug/obj/
coreclr-pal-bug/libstack_probe.so

dotnet-c-reproducer/bin/
dotnet-c-reproducer/obj/
